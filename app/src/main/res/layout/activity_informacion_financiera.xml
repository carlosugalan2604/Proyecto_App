<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#F5F5F5">

    <androidx.appcompat.widget.Toolbar
        android:id="@+id/toolbar"
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize"
        android:background="#00CC99"
        app:title="Información Financiera"
        app:titleTextColor="#FFFFFF"
        app:navigationIconTint="#FFFFFF" />

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- TARJETA RESUMEN TOTAL -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                app:cardCornerRadius="12dp"
                app:cardElevation="4dp"
                app:cardBackgroundColor="#00CC99">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp"
                    android:gravity="center">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Ingresos Totales"
                        android:textSize="14sp"
                        android:textColor="#E0F7F4" />

                    <TextView
                        android:id="@+id/tvTotalIngresos"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="€ 0.00"
                        android:textSize="36sp"
                        android:textStyle="bold"
                        android:textColor="#FFFFFF" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="(pedidos entregados)"
                        android:textSize="12sp"
                        android:textColor="#E0F7F4" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- TARJETA PEDIDOS ENTREGADOS -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                app:cardCornerRadius="10dp"
                app:cardElevation="3dp"
                app:cardBackgroundColor="#FFFFFF"
                app:strokeColor="#4CAF50"
                app:strokeWidth="2dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:padding="16dp"
                    android:gravity="center_vertical">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Pedidos Entregados"
                            android:textSize="14sp"
                            android:textColor="#212121"
                            android:textStyle="bold" />

                        <TextView
                            android:id="@+id/tvSumaEntregados"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="€ 0.00"
                            android:textSize="13sp"
                            android:textColor="#4CAF50" />
                    </LinearLayout>

                    <TextView
                        android:id="@+id/tvNumEntregados"
                        android:layout_width="48dp"
                        android:layout_height="48dp"
                        android:gravity="center"
                        android:text="0"
                        android:textSize="22sp"
                        android:textStyle="bold"
                        android:textColor="#FFFFFF"
                        android:background="#4CAF50" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- TARJETA PEDIDOS EN PROCESO -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                app:cardCornerRadius="10dp"
                app:cardElevation="3dp"
                app:cardBackgroundColor="#FFFFFF"
                app:strokeColor="#FF9800"
                app:strokeWidth="2dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:padding="16dp"
                    android:gravity="center_vertical">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Pedidos En Proceso"
                            android:textSize="14sp"
                            android:textColor="#212121"
                            android:textStyle="bold" />

                        <TextView
                            android:id="@+id/tvSumaEnProceso"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="€ 0.00"
                            android:textSize="13sp"
                            android:textColor="#FF9800" />
                    </LinearLayout>

                    <TextView
                        android:id="@+id/tvNumEnProceso"
                        android:layout_width="48dp"
                        android:layout_height="48dp"
                        android:gravity="center"
                        android:text="0"
                        android:textSize="22sp"
                        android:textStyle="bold"
                        android:textColor="#FFFFFF"
                        android:background="#FF9800" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- TARJETA PEDIDOS CANCELADOS -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                app:cardCornerRadius="10dp"
                app:cardElevation="3dp"
                app:cardBackgroundColor="#FFFFFF"
                app:strokeColor="#F44336"
                app:strokeWidth="2dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:padding="16dp"
                    android:gravity="center_vertical">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Pedidos Cancelados"
                            android:textSize="14sp"
                            android:textColor="#212121"
                            android:textStyle="bold" />

                        <TextView
                            android:id="@+id/tvSumaCancelados"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="€ 0.00"
                            android:textSize="13sp"
                            android:textColor="#F44336" />
                    </LinearLayout>

                    <TextView
                        android:id="@+id/tvNumCancelados"
                        android:layout_width="48dp"
                        android:layout_height="48dp"
                        android:gravity="center"
                        android:text="0"
                        android:textSize="22sp"
                        android:textStyle="bold"
                        android:textColor="#FFFFFF"
                        android:background="#F44336" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- GRÁFICO DE BARRAS SIMPLE -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="10dp"
                app:cardElevation="3dp"
                app:cardBackgroundColor="#FFFFFF">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Distribución de pedidos"
                        android:textSize="15sp"
                        android:textStyle="bold"
                        android:textColor="#212121"
                        android:layout_marginBottom="12dp" />

                    <!-- Barra Entregados -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Entregados"
                        android:textSize="12sp"
                        android:textColor="#757575"
                        android:layout_marginBottom="4dp" />
                    <FrameLayout
                        android:layout_width="match_parent"
                        android:layout_height="28dp"
                        android:background="#E8F5E9"
                        android:layout_marginBottom="12dp">
                        <View
                            android:id="@+id/barraEntregados"
                            android:layout_width="0dp"
                            android:layout_height="match_parent"
                            android:background="#4CAF50" />
                        <TextView
                            android:id="@+id/tvPctEntregados"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_gravity="center_vertical|end"
                            android:text="0%"
                            android:textSize="12sp"
                            android:textColor="#212121"
                            android:paddingEnd="6dp" />
                    </FrameLayout>

                    <!-- Barra En Proceso -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="En proceso"
                        android:textSize="12sp"
                        android:textColor="#757575"
                        android:layout_marginBottom="4dp" />
                    <FrameLayout
                        android:layout_width="match_parent"
                        android:layout_height="28dp"
                        android:background="#FFF3E0"
                        android:layout_marginBottom="12dp">
                        <View
                            android:id="@+id/barraEnProceso"
                            android:layout_width="0dp"
                            android:layout_height="match_parent"
                            android:background="#FF9800" />
                        <TextView
                            android:id="@+id/tvPctEnProceso"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_gravity="center_vertical|end"
                            android:text="0%"
                            android:textSize="12sp"
                            android:textColor="#212121"
                            android:paddingEnd="6dp" />
                    </FrameLayout>

                    <!-- Barra Cancelados -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Cancelados"
                        android:textSize="12sp"
                        android:textColor="#757575"
                        android:layout_marginBottom="4dp" />
                    <FrameLayout
                        android:layout_width="match_parent"
                        android:layout_height="28dp"
                        android:background="#FFEBEE">
                        <View
                            android:id="@+id/barraCancelados"
                            android:layout_width="0dp"
                            android:layout_height="match_parent"
                            android:background="#F44336" />
                        <TextView
                            android:id="@+id/tvPctCancelados"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_gravity="center_vertical|end"
                            android:text="0%"
                            android:textSize="12sp"
                            android:textColor="#212121"
                            android:paddingEnd="6dp" />
                    </FrameLayout>

                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

        </LinearLayout>
    </ScrollView>

</LinearLayout>
